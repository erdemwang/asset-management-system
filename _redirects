export function previewUrl(id){ return `https://drive.google.com/file/d/${id}/view`; }
export function downloadUrl(id){ return `https://drive.google.com/uc?export=download&id=${id}`; }

export async function loadDriveFiles(){
  try{
    const res = await fetch('/.netlify/functions/sync-drive');
    if(!res.ok) throw new Error('Drive sync unavailable');
    const data = await res.json();
    return Array.isArray(data.files) ? data.files : [];
  }catch(err){
    return [];
  }
}
